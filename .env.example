# Copy to .env and fill in values. Do not commit .env.

# YouTube Data API v3 (Google Cloud API key with YouTube Data API v3 enabled)
YOUTUBE_API_KEY=

# Optional: used if YOUTUBE_API_KEY is empty (same key is fine)
GOOGLE_API_KEY=

# OpenAI (orchestrator + source assessment)
OPENAI_API_KEY=

# Serper (Google search in search_service)
SERPER_API_KEY=
